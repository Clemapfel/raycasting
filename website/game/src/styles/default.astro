---
import { theme } from "./default.ts";
---

<style define:vars={{
    default_color_primary: theme.color_primary,
    default_color_secondary: theme.color_secondary,
    default_color_foreground: theme.color_foreground,
    default_color_muted: theme.color_muted,
    default_color_emphasized: theme.color_emphasized,
    default_color_background: theme.color_background,
}}>
  :root {
      --default-font: "Cantarelle", "Noto Sans", sans-serif;
      --default-font-mono: "DejaVu Mono", "Noto Sans Mono", monospace;
      --default-color-primary: var(--default-color-primary);
      --default-color-secondary: var(--default-color-secondary);
      --default-color-foreground: var(--default-color-foreground);
      --default-color-muted: var(--default-color-muted);
      --default-color-emphasized: var(--default-color-emphasized);
      --default-color-background: var(--default-color-background);
      --default-content-width: 66.6666vw;
      --default-frame-thickness: 6px;
  }
</style>