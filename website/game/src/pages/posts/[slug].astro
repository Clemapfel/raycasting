---
import { getCollection } from 'astro:content';

import Layout from '../../layouts/Layout.astro';
import MarkdownRenderer from '../../components/Markdown.astro';
import ShaderCanvas from '../../components/ShaderCanvas.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
    return (await getCollection('posts')).map(post => ({
        params: { slug: post.data.slug },
        props: { post },
    }));
}

const { post } = Astro.props;

console.log(post.data.shader)
---

<Layout>
    <ShaderCanvas id={post.data.shader} />
    <!-- MarkdownRenderer id={post.data.slug} /-->
    <Footer author="C. Cords" />
</Layout>