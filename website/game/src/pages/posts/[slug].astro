---
import { getCollection } from "astro:content";

import Layout from "../../layouts/base_layout.astro";
import MarkdownRenderer from "../../components/markdown.astro";
import ShaderCanvas from "../../components/shader_canvas.astro";
import Footer from "../../components/footer.astro";

export async function getStaticPaths() {
    return (await getCollection("posts")).map(post => ({
        params: { slug: post.data.slug },
        props: { post },
    }));
}

const { post } = Astro.props;
---

<Layout>
    <ShaderCanvas id={post.data.shader} />
    <MarkdownRenderer id={post.data.slug} />
    <Footer author="C. Cords" />
</Layout>