---


<orb-canvas>
    <canvas class="orb-canvas-canvas"></canvas>
</orb-canvas>

<style>
    orb-canvas {
        --orb-width: 400px;
        --orb-height: 400px;

        display: inline;
        width: var(--orb-width);
        height: var(--orb-height);
        background: black;
    }

    orb-canvas .noise-frame-canvas {
        width: var(--orb-width);
        height: var(--orb-height);
    }
</style>


<script>
    import { Orb } from "./orb.ts";
    import { register } from "../common/register_component.ts"
    register("orb-canvas", Orb)
</script>