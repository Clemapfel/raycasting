---
//
// Usage: <Orb />
//
---


<orb-canvas>
    <canvas class="orb-canvas-canvas"></canvas>
</orb-canvas>

<style>
    orb-canvas {
        display: inline-block;
        height: 100%;
        width: auto;
        min-height: 120px;
        aspect-ratio: 1 / 1;
    }

    orb-canvas .orb-canvas-canvas {
        width: 100%;
        height: 100%;
        background: transparent;
    }
</style>

<script>
    import { Orb } from "./orb.ts";
    import { register } from "../common/register_component.ts"
    register("orb-canvas", Orb)
</script>