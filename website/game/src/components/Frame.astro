---
interface Props {
    segmentDistance?: number;
    maxOffset?: number;
    noiseSpeed?: number;
    noiseFrequency?: number;
    noiseMaxOffset?: number;
    backgroundColor?: string;
    outlineColor?: string;
    outlineWidth?: number;
    cornerRadius?: number;
    thickness?: number;
    colorSpeed?: number;
}

const {
    segmentDistance = 8,
    maxOffset = 4,
    noiseSpeed = 0.25,
    noiseFrequency = 20,
    backgroundColor = "#111111",
    outlineColor = "currentColor",
    outlineWidth = 2,
    cornerRadius = 16,
    thickness = 4,
    colorSpeed = 0.05,
} = Astro.props;

import '../styles/default.css';
---

<div
    class="noisy-frame"
    data-segment-distance={segmentDistance}
    data-max-offset={maxOffset}
    data-noise-frequency={noiseFrequency}
    data-corner-radius={cornerRadius}
    data-color-speed={colorSpeed}
>
    <svg class="noisy-frame__svg" aria-hidden="true" preserveAspectRatio="none">
        <path class="noisy-frame__bg-and-outline" />
        <path class="noisy-frame__path" />
    </svg>
    <div class="noisy-frame__content">
        <slot />
    </div>
</div>

<style define:vars={{
    "nf-bg-color": backgroundColor,
    "nf-outline-color": outlineColor,
    "nf-outline-width": `${outlineWidth}px`,
    "nf-corner-radius": `${cornerRadius}px`,
    "nf-thickness": `${thickness}px`,
}}>
    .noisy-frame {
        position: relative;
        display: flex;
        flex-direction: column;
        box-sizing: border-box;
        isolation: isolate;

        margin: 20px
    }

    .noisy-frame__svg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        overflow: visible;
        z-index: 0;
    }

    .noisy-frame__bg-and-outline {
        fill: var(--nf-bg-color);
        stroke: var(--nf-outline-color);
        /* Thicker stroke to create the outline effect around the border */
        stroke-width: calc(var(--nf-thickness) + (var(--nf-outline-width) * 2));
        stroke-linejoin: round;
        stroke-linecap: round;
        vector-effect: non-scaling-stroke;
    }

    .noisy-frame__path {
        fill: none;
        stroke-width: var(--nf-thickness);
        stroke-linejoin: round;
        stroke-linecap: round;
        vector-effect: non-scaling-stroke;
    }

    .noisy-frame__content {
        position: relative;
        z-index: 1;
        flex: 1;
        box-sizing: border-box;
        width: 100%;
        height: 100%;
        padding: calc(var(--nf-corner-radius) / 2 + var(--nf-thickness) + var(--nf-outline-width));
    }
</style>

<script>
    // ---------- 3D Perlin noise (classic Ken Perlin, continuous in all 3 dims) ----------
    const perm = new Uint8Array(512);
    {
        const p = new Uint8Array(256);
        for (let i = 0; i < 256; i++) p[i] = i;
        let seed = 1337;
        const rand = () => {
            seed = (seed * 16807) % 2147483647;
            return seed / 2147483647;
        };
        for (let i = 255; i > 0; i--) {
            const j = Math.floor(rand() * (i + 1));
            [p[i], p[j]] = [p[j], p[i]];
        }
        for (let i = 0; i < 512; i++) perm[i] = p[i & 255];
    }

    const fade = (t: number) => t * t * t * (t * (t * 6 - 15) + 10);
    const lerp = (a: number, b: number, t: number) => a + t * (b - a);

    function grad(hash: number, x: number, y: number, z: number): number {
        const h = hash & 15;
        const u = h < 8 ? x : y;
        const v = h < 4 ? y : h === 12 || h === 14 ? x : z;
        return ((h & 1) === 0 ? u : -u) + ((h & 2) === 0 ? v : -v);
    }

    function perlin3(x: number, y: number, z: number): number {
        const X = Math.floor(x) & 255;
        const Y = Math.floor(y) & 255;
        const Z = Math.floor(z) & 255;
        x -= Math.floor(x);
        y -= Math.floor(y);
        z -= Math.floor(z);
        const u = fade(x);
        const v = fade(y);
        const w = fade(z);
        const A = perm[X] + Y;
        const AA = perm[A] + Z;
        const AB = perm[A + 1] + Z;
        const B = perm[X + 1] + Y;
        const BA = perm[B] + Z;
        const BB = perm[B + 1] + Z;
        return lerp(
            lerp(
                lerp(grad(perm[AA], x, y, z), grad(perm[BA], x - 1, y, z), u),
                lerp(grad(perm[AB], x, y - 1, z), grad(perm[BB], x - 1, y - 1, z), u),
                v
            ),
            lerp(
                lerp(grad(perm[AA + 1], x, y, z - 1), grad(perm[BA + 1], x - 1, y, z - 1), u),
                lerp(grad(perm[AB + 1], x, y - 1, z - 1), grad(perm[BB + 1], x - 1, y - 1, z - 1), u),
                v
            ),
            w
        );
    }

    interface ContourSample {
        x: number;
        y: number;
        nx: number;
        ny: number;
    }

    function sampleContour(
        w: number,
        h: number,
        r: number,
        segDist: number
    ): ContourSample[] {
        r = Math.max(0, Math.min(r, Math.min(w, h) / 2));

        const straightTop = w - 2 * r;
        const straightRight = h - 2 * r;
        const straightBottom = w - 2 * r;
        const straightLeft = h - 2 * r;
        const arcLen = (Math.PI / 2) * r;
        const perimeter =
            straightTop + arcLen + straightRight + arcLen + straightBottom + arcLen + straightLeft + arcLen;

        if (perimeter <= 0) return [];

        const n = Math.max(8, Math.round(perimeter / segDist));
        const step = perimeter / n;

        const b0 = 0;
        const b1 = b0 + straightTop;
        const b2 = b1 + arcLen;
        const b3 = b2 + straightRight;
        const b4 = b3 + arcLen;
        const b5 = b4 + straightBottom;
        const b6 = b5 + arcLen;
        const b7 = b6 + straightLeft;

        const samples: ContourSample[] = new Array(n);

        for (let i = 0; i < n; i++) {
            const s = i * step;
            let x = 0, y = 0, nx = 0, ny = 0;

            if (s < b1) {
                const t = s - b0;
                x = r + t;
                y = 0;
                nx = 0;
                ny = -1;
            } else if (s < b2) {
                const t = (s - b1) / arcLen;
                const a = -Math.PI / 2 + t * (Math.PI / 2);
                x = w - r + r * Math.cos(a);
                y = r + r * Math.sin(a);
                nx = Math.cos(a);
                ny = Math.sin(a);
            } else if (s < b3) {
                const t = s - b2;
                x = w;
                y = r + t;
                nx = 1;
                ny = 0;
            } else if (s < b4) {
                const t = (s - b3) / arcLen;
                const a = t * (Math.PI / 2);
                x = w - r + r * Math.cos(a);
                y = h - r + r * Math.sin(a);
                nx = Math.cos(a);
                ny = Math.sin(a);
            } else if (s < b5) {
                const t = s - b4;
                x = w - r - t;
                y = h;
                nx = 0;
                ny = 1;
            } else if (s < b6) {
                const t = (s - b5) / arcLen;
                const a = Math.PI / 2 + t * (Math.PI / 2);
                x = r + r * Math.cos(a);
                y = h - r + r * Math.sin(a);
                nx = Math.cos(a);
                ny = Math.sin(a);
            } else if (s < b7) {
                const t = s - b6;
                x = 0;
                y = h - r - t;
                nx = -1;
                ny = 0;
            } else {
                const t = (s - b7) / arcLen;
                const a = Math.PI + t * (Math.PI / 2);
                x = r + r * Math.cos(a);
                y = r + r * Math.sin(a);
                nx = Math.cos(a);
                ny = Math.sin(a);
            }

            samples[i] = { x, y, nx, ny };
        }

        return samples;
    }

    class NoisyFrameController {
        private root: HTMLElement;
        private svg: SVGSVGElement;
        private path: SVGPathElement;
        private bgOutlinePath: SVGPathElement;
        private samples: ContourSample[] = [];
        private width = 0;
        private height = 0;
        private resizeObserver: ResizeObserver;
        private rafId = 0;
        private startTime = 0;
        private visible = true;
        private intersectionObserver: IntersectionObserver;

        private segmentDistance: number;
        private maxOffset: number;
        private noiseSpeed: number;
        private noiseFrequency: number;
        private noiseMaxOffset: number;
        private cornerRadius: number;
        private colorSpeed: number;

        constructor(root: HTMLElement) {
            this.root = root;
            this.svg = root.querySelector(".noisy-frame__svg") as SVGSVGElement;
            this.path = root.querySelector(".noisy-frame__path") as SVGPathElement;
            this.bgOutlinePath = root.querySelector(".noisy-frame__bg-and-outline") as SVGPathElement;

            this.segmentDistance = parseFloat(root.dataset.segmentDistance ?? "8");
            this.maxOffset = parseFloat(root.dataset.maxOffset ?? "6");
            this.noiseSpeed = parseFloat(root.dataset.noiseSpeed ?? "0.25");
            this.noiseFrequency = parseFloat(root.dataset.noiseFrequency ?? "1");
            this.noiseMaxOffset = parseFloat(root.dataset.noiseMaxOffset ?? "0");
            this.cornerRadius = parseFloat(root.dataset.cornerRadius ?? "16");
            this.colorSpeed = parseFloat(root.dataset.colorSpeed ?? "0.05");

            this.resizeObserver = new ResizeObserver(() => this.onResize());
            this.resizeObserver.observe(root);

            this.intersectionObserver = new IntersectionObserver(
                (entries) => {
                    for (const entry of entries) {
                        this.visible = entry.isIntersecting;
                    }
                    if (this.visible && !this.rafId) this.loop();
                },
                { threshold: 0 }
            );
            this.intersectionObserver.observe(root);

            this.startTime = performance.now();
            this.onResize();
            this.loop();
        }

        private onResize() {
            const rect = this.root.getBoundingClientRect();
            this.width = rect.width;
            this.height = rect.height;
            this.svg.setAttribute("viewBox", `0 0 ${this.width} ${this.height}`);
            this.svg.setAttribute("width", `${this.width}`);
            this.svg.setAttribute("height", `${this.height}`);
            this.samples = sampleContour(
                this.width,
                this.height,
                this.cornerRadius,
                this.segmentDistance
            );
        }

        private buildPath(t: number): string {
            const n = this.samples.length;
            if (n === 0) return "";

            const tz = t * this.noiseSpeed;
            const spatialRadius = 1;

            let d = "";
            for (let i = 0; i < n; i++) {
                const s = this.samples[i];
                const theta = (i / n) * Math.PI * 2;
                const nx_noise = Math.cos(theta) * spatialRadius;
                const ny_noise = Math.sin(theta) * spatialRadius;

                const raw = perlin3(nx_noise * this.noiseFrequency, ny_noise * this.noiseFrequency, tz);
                const norm = Math.max(-1, Math.min(1, raw / 0.7));
                const offset = norm * this.maxOffset;
                const x = s.x + s.nx * offset;
                const y = s.y + s.ny * offset;
                d += (i === 0 ? "M" : "L") + x.toFixed(2) + "," + y.toFixed(2);
            }
            d += "Z";
            return d;
        }

        private loop = () => {
            if (!this.visible) {
                this.rafId = 0;
                return;
            }
            const elapsed = (performance.now() - this.startTime) / 1000;
            const d = this.buildPath(elapsed);

            // Sync both the outline/background and the dynamic stroke to prevent any gaps
            this.bgOutlinePath.setAttribute("d", d);
            this.path.setAttribute("d", d);

            // Compute LCH(0.8, 1, t, 1) mapping `t` across the 360 degree hue space
            const colorT = (elapsed * this.colorSpeed) % 1;
            const hue = colorT * 360;
            this.path.style.stroke = `lch(80% 100 ${hue} / 1)`;

            this.rafId = requestAnimationFrame(this.loop);
        };

        destroy() {
            cancelAnimationFrame(this.rafId);
            this.resizeObserver.disconnect();
            this.intersectionObserver.disconnect();
        }
    }

    const controllers = new WeakMap<HTMLElement, NoisyFrameController>();

    function init() {
        const frames = document.querySelectorAll<HTMLElement>(".noisy-frame");
        frames.forEach((el) => {
            if (!controllers.has(el)) {
                controllers.set(el, new NoisyFrameController(el));
            }
        });
    }

    init();
    document.addEventListener("astro:page-load", init);
</script>