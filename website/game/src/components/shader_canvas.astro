---
//
// Usage: <ShaderCanvas id="shader_id"/>
//

import { getEntry } from "astro:content";

interface Props {
    /** The ID of the shader entry in the 'shaders' content collection */
    id: string;
}

const { id } = Astro.props;

if (!id) {
    throw new Error("In ShaderCanvas: `id` property not specified");
}

const fragment_shader_entry = await getEntry("shaders", id);
const fragment_shader = fragment_shader_entry?.body;

if (!fragment_shader) {
    throw new Error(`FragmentShader not found: ${id}`);
}
---

<shader-canvas fragment-shader-source={fragment_shader}>
    <canvas class="shader-canvas-canvas"></canvas>
</shader-canvas>

<style>
    :root {
        --canvas-width: 100%;
        --canvas-height: 100%;
    }

    shader-canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: var(--canvas-width);
        height: var(--canvas-height);
        z-index: -9999;
    }

    .shader-canvas-canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: var(--canvas-width);
        height: var(--canvas-height);
    }
</style>

<script>
    import { ShaderCanvas } from "./shader_canvas.ts";

    function register() {
        if (!customElements.get("shader-canvas"))
            customElements.define("shader-canvas", ShaderCanvas);
    }

    register();
    document.addEventListener("astro:page-load", register, { once: false });
</script>