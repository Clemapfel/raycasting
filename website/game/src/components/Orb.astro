---
// src/components/OrbRenderer.astro
const image_path = "/orb_particle_texture.png"
---

<script>
    const n_particles: number = 32 + 16;
    const n_sub_steps: number = 3;
    const n_constraint_iterations: number = 2;
    const gravity: number = 2000;
    const gravity_dx: number = 0;
    const gravity_dy: number = 1;
    const swirl_strength: number = gravity * 0.25;

    const radius: number = 128;
    const padding: number = 16;
    const texture_scale: number = 2;

    const max_agitation: number = 2;
    const agitation_duration: number = 1.5;

    const min_radius: number = 10;
    const max_radius: number = 15;
    const min_radius_frequency: number = 0.75;
    const max_radius_frequency: number = 1.25;
    const min_radius_scale: number = 1;
    const max_radius_scale: number = 2;

    const threshold: number = 0.3;
    const eps: number = 0.05;
    const blend_strength: number = 1;

    const _x_offset = 0;
    const _y_offset = 1;
    const _previous_x_offset = 2;
    const _previous_y_offset = 3;
    const _velocity_x_offset = 4;
    const _velocity_y_offset = 5;
    const _radius_offset = 6;
    const _radius_cycle_offset = 7;
    const _swirl_direction_offset = 8;
    const _inverse_mass_offset = 9;
    const _orb_lambda_offset = 10;
    const _r_offset = 11;
    const _g_offset = 12;
    const _b_offset = 13;
    const _a_offset = 14;

    // ---------- WebGL Shaders ----------
    const vertex_shader_source = `#version 300 es
        in vec2 position;
        in vec2 uv;
        in vec4 color;

        uniform vec2 canvas_size;
        uniform vec2 offset;

        out vec2 fragment_uv;
        out vec4 fragment_color;

        void main() {
            vec2 p = position + offset;
            vec2 clip = (p / canvas_size) * 2.0 - 1.0;
            gl_Position = vec4(clip.x, -clip.y, 0.0, 1.0);
            fragment_uv = uv;
            fragment_color = color;
        }
    `;

    const fragment_shader_source = `#version 300 es
        precision mediump float;

        in vec2 fragment_uv;
        in vec4 fragment_color;

        uniform sampler2D particle_texture;

        out vec4 out_color;

        void main() {
            vec4 texel = texture(particle_texture, fragment_uv);
            out_color = texel * fragment_color;
        }
    `;

    const stencil_vertex_shader_source = `#version 300 es
        in vec2 position;

        uniform vec2 canvas_size;
        uniform vec2 offset;

        void main() {
            vec2 p = position + offset;
            vec2 clip = (p / canvas_size) * 2.0 - 1.0;
            gl_Position = vec4(clip.x, -clip.y, 0.0, 1.0);
        }
    `;

    const stencil_fragment_shader_source = `#version 300 es
        precision mediump float;

        out vec4 out_color;

        void main() {
            out_color = vec4(0.0);
        }
    `;

    const quad_vertex_shader_source = `#version 300 es
        in vec2 a_position;
        in vec2 a_texcoord;

        out vec2 v_texcoord;

        void main() {
            gl_Position = vec4(a_position, 0.0, 1.0);
            v_texcoord = a_texcoord;
        }
    `;

    const quad_fragment_shader_source = `#version 300 es
        precision mediump float;

        in vec2 v_texcoord;

        uniform sampler2D u_renderTexture;
        uniform float u_threshold;
        uniform float u_eps;

        out vec4 out_color;
        
        vec3 lch_to_rgb(vec3 lch) {
            float L = lch.x * 100.0;
            float C = lch.y * 100.0;
            float H = lch.z * 360.0;
        
            float a = cos(radians(H)) * C;
            float b = sin(radians(H)) * C;
        
            float Y = (L + 16.0) / 116.0;
            float X = a / 500.0 + Y;
            float Z = Y - b / 200.0;
        
            X = 0.95047 * ((X * X * X > 0.008856) ? X * X * X : (X - 16.0 / 116.0) / 7.787);
            Y = 1.00000 * ((Y * Y * Y > 0.008856) ? Y * Y * Y : (Y - 16.0 / 116.0) / 7.787);
            Z = 1.08883 * ((Z * Z * Z > 0.008856) ? Z * Z * Z : (Z - 16.0 / 116.0) / 7.787);
        
            float R = X *  3.2406 + Y * -1.5372 + Z * -0.4986;
            float G = X * -0.9689 + Y *  1.8758 + Z *  0.0415;
            float B = X *  0.0557 + Y * -0.2040 + Z *  1.0570;
        
            R = (R > 0.0031308) ? 1.055 * pow(R, 1.0 / 2.4) - 0.055 : 12.92 * R;
            G = (G > 0.0031308) ? 1.055 * pow(G, 1.0 / 2.4) - 0.055 : 12.92 * G;
            B = (B > 0.0031308) ? 1.055 * pow(B, 1.0 / 2.4) - 0.055 : 12.92 * B;
        
            return vec3(clamp(R, 0.0, 1.0), clamp(G, 0.0, 1.0), clamp(B, 0.0, 1.0));
        }

        void main() {
            vec4 texColor = texture(u_renderTexture, v_texcoord);
            float lum = texColor.a;
            float alpha = smoothstep(u_threshold - u_eps, u_threshold + u_eps, min(1.0, lum));
            out_color = vec4(lch_to_rgb(vec3(0.8, 1, max(max(texColor.r, texColor.g), texColor.b))), alpha);
        }
    `;

    class OrbRenderer {
        // --- WebGL Context & DOM ---
        private canvas: HTMLCanvasElement;
        private gl: WebGL2RenderingContext;
        private canvasWidth: number = 0;
        private canvasHeight: number = 0;
        private useFloatTexture: boolean = false;

        // --- Simulation State ---
        private n_particles!: number;
        private damping!: number;
        private gravity_dx!: number;
        private gravity_dy!: number;
        private gravity!: number;
        private n_sub_steps!: number;
        private n_constraint_iterations!: number;
        private collision_compliance!: number;
        private orb_compliance!: number;
        private min_radius!: number;
        private max_radius!: number;
        private min_radius_frequency!: number;
        private max_radius_frequency!: number;
        private max_agitation!: number;
        private agitation_elapsed!: number;
        private agitation_duration!: number;
        private elapsed!: number;
        private texture_scale!: number;
        private timestamp!: number;
        public is_paused: boolean = false;
        private orb_center_x!: number;
        private orb_center_y!: number;
        private orb_radius!: number;

        private particle_data_stride!: number;
        private particle_data!: Float32Array;
        private particle_collision_lambdas!: Float32Array;
        private mesh_vertex_stride!: number;
        private mesh_data_stride!: number;
        private mesh_data!: Float32Array;
        private mesh_vertex_map_stride!: number;
        private mesh_vertex_map!: Uint16Array;

        // --- WebGL State ---
        private program!: WebGLProgram;
        private stencil_program!: WebGLProgram;
        private quad_program!: WebGLProgram;

        private vao!: WebGLVertexArrayObject;
        private vertexBuffer!: WebGLBuffer;
        private indexBuffer!: WebGLBuffer;

        private n_circle_segments = 64;
        private circle_vertices!: Float32Array;
        private circleVao!: WebGLVertexArrayObject;
        private circleVertexBuffer!: WebGLBuffer;
        private circleIndexBuffer!: WebGLBuffer;

        private quadVao!: WebGLVertexArrayObject;
        private quadPositionBuffer!: WebGLBuffer;
        private quadTexcoordBuffer!: WebGLBuffer;
        private quadIndexBuffer!: WebGLBuffer;

        private renderTexWidth: number = 0;
        private renderTexHeight: number = 0;
        private renderTexture: WebGLTexture | null = null;
        private stencilRenderbuffer: WebGLRenderbuffer | null = null;
        private fbo: WebGLFramebuffer | null = null;
        private particleTexture!: WebGLTexture;

        private offsetUniform = [0.0, 0.0];
        private previous_timestamp: number = performance.now();

        private locs!: {
            particle: {
                pos: number; uv: number; color: number;
                canvasSize: WebGLUniformLocation | null;
                offset: WebGLUniformLocation | null;
                texture: WebGLUniformLocation | null;
            };
            stencil: {
                pos: number;
                canvasSize: WebGLUniformLocation | null;
                offset: WebGLUniformLocation | null;
            };
            quad: {
                pos: number; texcoord: number;
                renderTexture: WebGLUniformLocation | null;
                threshold: WebGLUniformLocation | null;
                eps: WebGLUniformLocation | null;
            };
        };

        constructor(canvasId: string) {
            this.canvas = document.getElementById(canvasId) as HTMLCanvasElement;
            const dpr = window.devicePixelRatio || 1;
            this.canvasWidth = 2.0 * radius + 2.0 * padding * dpr;
            this.canvasHeight = 2.0 * radius + 2.0 * padding * dpr;
            this.canvas.width = this.canvasWidth;
            this.canvas.height = this.canvasHeight;
            this.canvas.style.width = `${this.canvas.width}px`;
            this.canvas.style.height = `${this.canvas.height}px`;

            const glContext = this.canvas.getContext("webgl2", { stencil: true });
            if (!glContext) throw new Error("WebGL2 not supported");
            this.gl = glContext;

            // Check extensions
            const extColorBufferFloat = this.gl.getExtension('EXT_color_buffer_float');
            const extFloatBlend = this.gl.getExtension('EXT_float_blend');
            if (extColorBufferFloat) {
                this.useFloatTexture = true;
                if (!extFloatBlend) {
                    console.warn('EXT_float_blend not available, additive blending may behave unexpectedly with float textures');
                }
            } else {
                console.warn('EXT_color_buffer_float not available, falling back to RGBA8 render texture.');
            }

            this.initWebGL();
            this.initializeSimulation(this.canvasWidth, this.canvasHeight);

            // Upload static data
            this.gl.bindBuffer(this.gl.ELEMENT_ARRAY_BUFFER, this.indexBuffer);
            this.gl.bufferData(this.gl.ELEMENT_ARRAY_BUFFER, this.mesh_vertex_map, this.gl.STATIC_DRAW);

            this.setupRenderTarget();
            this.bindEvents();

            requestAnimationFrame(this.renderFrame);
        }

        // ====================================================================
        // WebGL Local Helpers (Reduces boilerplate/duplication)
        // ====================================================================

        private compileShader(type: number, source: string): WebGLShader {
            const shader = this.gl.createShader(type)!;
            this.gl.shaderSource(shader, source);
            this.gl.compileShader(shader);
            if (!this.gl.getShaderParameter(shader, this.gl.COMPILE_STATUS)) {
                throw new Error(this.gl.getShaderInfoLog(shader)!);
            }
            return shader;
        }

        private createProgram(vertexSource: string, fragmentSource: string): WebGLProgram {
            const program = this.gl.createProgram()!;
            this.gl.attachShader(program, this.compileShader(this.gl.VERTEX_SHADER, vertexSource));
            this.gl.attachShader(program, this.compileShader(this.gl.FRAGMENT_SHADER, fragmentSource));
            this.gl.linkProgram(program);
            if (!this.gl.getProgramParameter(program, this.gl.LINK_STATUS)) {
                throw new Error(this.gl.getProgramInfoLog(program)!);
            }
            return program;
        }

        private createBuffer(target: number, data: BufferSource | null, usage: number): WebGLBuffer {
            const buffer = this.gl.createBuffer()!;
            this.gl.bindBuffer(target, buffer);
            if (data) this.gl.bufferData(target, data, usage);
            return buffer;
        }

        private setupAttribute(location: number, size: number, stride: number, offset: number) {
            if (location !== -1) {
                this.gl.enableVertexAttribArray(location);
                this.gl.vertexAttribPointer(location, size, this.gl.FLOAT, false, stride, offset);
            }
        }

        private initWebGL() {
            this.program = this.createProgram(vertex_shader_source, fragment_shader_source);
            this.stencil_program = this.createProgram(stencil_vertex_shader_source, stencil_fragment_shader_source);
            this.quad_program = this.createProgram(quad_vertex_shader_source, quad_fragment_shader_source);

            this.locs = {
                particle: {
                    pos: this.gl.getAttribLocation(this.program, "position"),
                    uv: this.gl.getAttribLocation(this.program, "uv"),
                    color: this.gl.getAttribLocation(this.program, "color"),
                    canvasSize: this.gl.getUniformLocation(this.program, "canvas_size"),
                    offset: this.gl.getUniformLocation(this.program, "offset"),
                    texture: this.gl.getUniformLocation(this.program, "particle_texture"),
                },
                stencil: {
                    pos: this.gl.getAttribLocation(this.stencil_program, "position"),
                    canvasSize: this.gl.getUniformLocation(this.stencil_program, "canvas_size"),
                    offset: this.gl.getUniformLocation(this.stencil_program, "offset"),
                },
                quad: {
                    pos: this.gl.getAttribLocation(this.quad_program, "a_position"),
                    texcoord: this.gl.getAttribLocation(this.quad_program, "a_texcoord"),
                    renderTexture: this.gl.getUniformLocation(this.quad_program, "u_renderTexture"),
                    threshold: this.gl.getUniformLocation(this.quad_program, "u_threshold"),
                    eps: this.gl.getUniformLocation(this.quad_program, "u_eps"),
                }
            };

            const float_size = Float32Array.BYTES_PER_ELEMENT;

            // 1. Particle VAO
            this.vao = this.gl.createVertexArray()!;
            this.gl.bindVertexArray(this.vao);
            this.vertexBuffer = this.createBuffer(this.gl.ARRAY_BUFFER, null, this.gl.DYNAMIC_DRAW);
            const vertex_stride_bytes = 8 * float_size;
            this.setupAttribute(this.locs.particle.pos, 2, vertex_stride_bytes, 0);
            this.setupAttribute(this.locs.particle.uv, 2, vertex_stride_bytes, 2 * float_size);
            this.setupAttribute(this.locs.particle.color, 4, vertex_stride_bytes, 4 * float_size);
            this.indexBuffer = this.createBuffer(this.gl.ELEMENT_ARRAY_BUFFER, null, this.gl.DYNAMIC_DRAW);
            this.gl.bindVertexArray(null);

            // 2. Circle Stencil VAO
            this.circle_vertices = new Float32Array((1 + this.n_circle_segments) * 2);
            this.circleVao = this.gl.createVertexArray()!;
            this.gl.bindVertexArray(this.circleVao);
            this.circleVertexBuffer = this.createBuffer(this.gl.ARRAY_BUFFER, null, this.gl.DYNAMIC_DRAW);
            this.setupAttribute(this.locs.stencil.pos, 2, 2 * float_size, 0);
            const circle_indices = new Uint16Array(this.n_circle_segments * 3);
            for (let i = 0; i < this.n_circle_segments; i++) {
                circle_indices[i * 3 + 0] = 0;
                circle_indices[i * 3 + 1] = 1 + i;
                circle_indices[i * 3 + 2] = 1 + (i + 1) % this.n_circle_segments;
            }
            this.circleIndexBuffer = this.createBuffer(this.gl.ELEMENT_ARRAY_BUFFER, circle_indices, this.gl.STATIC_DRAW);
            this.gl.bindVertexArray(null);

            // 3. Quad VAO
            const quad_positions = new Float32Array([-1, -1, 1, -1, 1, 1, -1, 1]);
            const quad_texcoords = new Float32Array([0, 0, 1, 0, 1, 1, 0, 1]);
            const quad_indices = new Uint16Array([0, 1, 2, 0, 2, 3]);

            this.quadVao = this.gl.createVertexArray()!;
            this.gl.bindVertexArray(this.quadVao);
            this.quadPositionBuffer = this.createBuffer(this.gl.ARRAY_BUFFER, quad_positions, this.gl.STATIC_DRAW);
            this.setupAttribute(this.locs.quad.pos, 2, 0, 0);
            this.quadTexcoordBuffer = this.createBuffer(this.gl.ARRAY_BUFFER, quad_texcoords, this.gl.STATIC_DRAW);
            this.setupAttribute(this.locs.quad.texcoord, 2, 0, 0);
            this.quadIndexBuffer = this.createBuffer(this.gl.ELEMENT_ARRAY_BUFFER, quad_indices, this.gl.STATIC_DRAW);
            this.gl.bindVertexArray(null);

            // 4. Particle Texture
            this.particleTexture = this.gl.createTexture()!;
            this.gl.activeTexture(this.gl.TEXTURE0);
            this.gl.bindTexture(this.gl.TEXTURE_2D, this.particleTexture);
            const placeholder = new Uint8Array([255, 255, 255, 255]);
            this.gl.texImage2D(this.gl.TEXTURE_2D, 0, this.gl.RGBA, 1, 1, 0, this.gl.RGBA, this.gl.UNSIGNED_BYTE, placeholder);

            const image = new Image();
            image.src = "/orb_particle_texture.png";
            image.onload = () => {
                this.gl.activeTexture(this.gl.TEXTURE0);
                this.gl.bindTexture(this.gl.TEXTURE_2D, this.particleTexture);
                this.gl.texImage2D(this.gl.TEXTURE_2D, 0, this.gl.RGBA, this.gl.RGBA, this.gl.UNSIGNED_BYTE, image);
                this.gl.generateMipmap(this.gl.TEXTURE_2D);
                this.gl.texParameteri(this.gl.TEXTURE_2D, this.gl.TEXTURE_MIN_FILTER, this.gl.LINEAR_MIPMAP_LINEAR);
                this.gl.texParameteri(this.gl.TEXTURE_2D, this.gl.TEXTURE_MAG_FILTER, this.gl.LINEAR);
                this.gl.texParameteri(this.gl.TEXTURE_2D, this.gl.TEXTURE_WRAP_S, this.gl.CLAMP_TO_EDGE);
                this.gl.texParameteri(this.gl.TEXTURE_2D, this.gl.TEXTURE_WRAP_T, this.gl.CLAMP_TO_EDGE);
            };
        }

        private setupRenderTarget() {
            if (this.renderTexture) this.gl.deleteTexture(this.renderTexture);
            if (this.stencilRenderbuffer) this.gl.deleteRenderbuffer(this.stencilRenderbuffer);
            if (this.fbo) this.gl.deleteFramebuffer(this.fbo);

            this.renderTexWidth = this.canvasWidth;
            this.renderTexHeight = this.canvasHeight;

            this.renderTexture = this.gl.createTexture()!;
            this.gl.bindTexture(this.gl.TEXTURE_2D, this.renderTexture);
            const internalFormat = this.useFloatTexture ? this.gl.RGBA16F : this.gl.RGBA8;
            const type = this.useFloatTexture ? this.gl.HALF_FLOAT : this.gl.UNSIGNED_BYTE;
            this.gl.texImage2D(this.gl.TEXTURE_2D, 0, internalFormat, this.renderTexWidth, this.renderTexHeight, 0, this.gl.RGBA, type, null);
            this.gl.texParameteri(this.gl.TEXTURE_2D, this.gl.TEXTURE_MIN_FILTER, this.gl.LINEAR);
            this.gl.texParameteri(this.gl.TEXTURE_2D, this.gl.TEXTURE_MAG_FILTER, this.gl.LINEAR);
            this.gl.texParameteri(this.gl.TEXTURE_2D, this.gl.TEXTURE_WRAP_S, this.gl.CLAMP_TO_EDGE);
            this.gl.texParameteri(this.gl.TEXTURE_2D, this.gl.TEXTURE_WRAP_T, this.gl.CLAMP_TO_EDGE);

            this.stencilRenderbuffer = this.gl.createRenderbuffer()!;
            this.gl.bindRenderbuffer(this.gl.RENDERBUFFER, this.stencilRenderbuffer);
            this.gl.renderbufferStorage(this.gl.RENDERBUFFER, this.gl.STENCIL_INDEX8, this.renderTexWidth, this.renderTexHeight);

            this.fbo = this.gl.createFramebuffer()!;
            this.gl.bindFramebuffer(this.gl.FRAMEBUFFER, this.fbo);
            this.gl.framebufferTexture2D(this.gl.FRAMEBUFFER, this.gl.COLOR_ATTACHMENT0, this.gl.TEXTURE_2D, this.renderTexture, 0);
            this.gl.framebufferRenderbuffer(this.gl.FRAMEBUFFER, this.gl.STENCIL_ATTACHMENT, this.gl.RENDERBUFFER, this.stencilRenderbuffer);

            const status = this.gl.checkFramebufferStatus(this.gl.FRAMEBUFFER);
            if (status !== this.gl.FRAMEBUFFER_COMPLETE) {
                throw new Error(`Framebuffer not complete: ${status}`);
            }

            this.gl.bindFramebuffer(this.gl.FRAMEBUFFER, null);
        }

        // ====================================================================
        // Simulation Methods (Intentionally untouched local functions per prompt)
        // ====================================================================

        private initializeSimulation(width: number, height: number) {
            this.n_particles = n_particles;
            this.damping = 0.95;

            let gravity_dxy = this.normalize(gravity_dx, gravity_dy);
            this.gravity_dx = gravity_dxy[0];
            this.gravity_dy = gravity_dxy[1];
            this.gravity = gravity;
            this.n_sub_steps = n_sub_steps;
            this.n_constraint_iterations = n_constraint_iterations;
            this.collision_compliance = 0.0001;
            this.orb_compliance = 0.0001;

            this.min_radius = min_radius;
            this.max_radius = max_radius;
            this.min_radius_frequency = min_radius_frequency;
            this.max_radius_frequency = max_radius_frequency;
            this.max_agitation = max_agitation;
            this.agitation_elapsed = Infinity;
            this.agitation_duration = agitation_duration;
            this.elapsed = 0;

            this.texture_scale = texture_scale;
            this.timestamp = performance.now() / 1000;
            this.is_paused = false;

            this.orb_center_x = width / 2;
            this.orb_center_y = height / 2;
            this.orb_radius = radius;

            this.particle_data_stride = _a_offset + 1;
            this.particle_data = new Float32Array(this.n_particles * this.particle_data_stride);

            const golden_angle = Math.PI * (3 - Math.sqrt(5));
            for (let particle_i = 0; particle_i < this.n_particles; particle_i++) {
                const i = this.particle_i_to_data_offset(particle_i, this.particle_data_stride);
                const t = particle_i / this.n_particles;

                const distance = this.orb_radius * Math.sqrt(t);
                const angle = particle_i * golden_angle;

                const position_x = this.orb_center_x + distance * Math.cos(angle);
                const position_y = this.orb_center_y + distance * Math.sin(angle);

                const mass_t = this.mass_distribution(t);
                const [r, g, b, _] = this.lcha_to_rgba(0.8, 1, t, 1);

                this.particle_data[i + _x_offset] = position_x;
                this.particle_data[i + _y_offset] = position_y;
                this.particle_data[i + _previous_x_offset] = position_x;
                this.particle_data[i + _previous_y_offset] = position_y;
                this.particle_data[i + _velocity_x_offset] = 0;
                this.particle_data[i + _velocity_y_offset] = 0;
                this.particle_data[i + _radius_offset] = this.mix(this.min_radius, this.max_radius, mass_t);
                this.particle_data[i + _radius_cycle_offset] = this.mix(this.min_radius_frequency, this.max_radius_frequency, Math.random());
                this.particle_data[i + _swirl_direction_offset] = i % 2 == 0 ? 1 : -1;
                this.particle_data[i + _inverse_mass_offset] = 1 / (1 + mass_t);
                this.particle_data[i + _orb_lambda_offset] = 0;
                this.particle_data[i + _r_offset] = r;
                this.particle_data[i + _g_offset] = g;
                this.particle_data[i + _b_offset] = b;
                this.particle_data[i + _a_offset] = 1;
            }

            this.particle_collision_lambdas = new Float32Array(this.n_particles * this.n_particles);

            this.mesh_vertex_stride = (2 + 2 + 4);
            this.mesh_data_stride = this.mesh_vertex_stride * 4;
            this.mesh_data = new Float32Array(this.n_particles * this.mesh_data_stride);

            this.mesh_vertex_map_stride = 6;
            this.mesh_vertex_map = new Uint16Array(this.n_particles * this.mesh_vertex_map_stride);

            for (let particle_i = 0; particle_i < this.n_particles; particle_i++) {
                const vertex_data_i = this.particle_i_to_data_offset(particle_i, this.mesh_vertex_map_stride);
                const vertex_base = particle_i * 4;

                this.mesh_vertex_map[vertex_data_i + 0] = vertex_base + 0;
                this.mesh_vertex_map[vertex_data_i + 1] = vertex_base + 1;
                this.mesh_vertex_map[vertex_data_i + 2] = vertex_base + 2;
                this.mesh_vertex_map[vertex_data_i + 3] = vertex_base + 0;
                this.mesh_vertex_map[vertex_data_i + 4] = vertex_base + 2;
                this.mesh_vertex_map[vertex_data_i + 5] = vertex_base + 3;
            }

            this.update_mesh_data();
        }

        private mass_distribution(t: number) {
            return Math.exp(-Math.pow((7 / 5) * Math.PI * (t - 0.5), 2));
        }

        private particle_i_to_data_offset(particle_i: number, stride: number) {
            return particle_i * stride;
        }

        private lcha_to_rgba(l: number, c: number, h: number, alpha: number) {
            const L = l * 100;
            const a = Math.cos(h * 6.283185) * c * 100;
            const b = Math.sin(h * 6.283185) * c * 100;

            let Y = (L + 16) * 0.008620689;
            let X = a * 0.002 + Y;
            let Z = Y - b * 0.005;

            const X3 = X * X * X, Y3 = Y * Y * Y, Z3 = Z * Z * Z;
            X = X3 > 0.008856 ? 0.95047 * X3 : 0.95047 * (X - 0.137931) * 0.128419;
            Y = Y3 > 0.008856 ? Y3 : (Y - 0.137931) * 0.128419;
            Z = Z3 > 0.008856 ? 1.08883 * Z3 : 1.08883 * (Z - 0.137931) * 0.128419;

            let R = X * 3.2406 - Y * 1.5372 - Z * 0.4986;
            let G = -X * 0.9689 + Y * 1.8758 + Z * 0.0415;
            let B = X * 0.0557 - Y * 0.2040 + Z * 1.0570;

            R = R > 0.0031308 ? 1.055 * Math.pow(R, 0.416666667) - 0.055 : 12.92 * R;
            G = G > 0.0031308 ? 1.055 * Math.pow(G, 0.416666667) - 0.055 : 12.92 * G;
            B = B > 0.0031308 ? 1.055 * Math.pow(B, 0.416666667) - 0.055 : 12.92 * B;

            return [
                R < 0 ? 0 : (R > 1 ? 1 : R),
                G < 0 ? 0 : (G > 1 ? 1 : G),
                B < 0 ? 0 : (B > 1 ? 1 : B),
                alpha
            ];
        }

        private particle_is_to_lambda_i(i1: number, i2: number, n: number) {
            return i1 * n + i2;
        }

        private mix(lower: number, upper: number, ratio: number) {
            return lower * (1 - ratio) + upper * ratio;
        }

        private dot(x1: number, y1: number, x2: number, y2: number) {
            return x1 * x2 + y1 * y2;
        }

        private squared_distance(x1: number, y1: number, x2: number, y2: number) {
            const dx = x2 - x1;
            const dy = y2 - y1;
            return this.dot(dx, dy, dx, dy);
        }

        private magnitude(x: number, y: number) {
            return Math.sqrt(x * x + y * y);
        }

        private distance(x1: number, y1: number, x2: number, y2: number) {
            const dx = x2 - x1;
            const dy = y2 - y1;
            return this.magnitude(dx, dy);
        }

        private normalize(x1: number, y1: number) {
            const magnitude = this.magnitude(x1, y1);
            if (magnitude < 1e-8) {
                return [0, 0];
            } else {
                return [x1 / magnitude, y1 / magnitude];
            }
        }

        private turn_left(x: number, y: number) {
            return [y, -x];
        }

        private turn_right(x: number, y: number) {
            return [-y, x];
        }

        private get_position() {
            return {
                position_x: this.orb_center_x,
                position_y: this.orb_center_y,
                radius: this.orb_radius
            }
        }

        private update_mesh_data() {
            const now = performance.now() / 1000;
            const elapsed = now - this.timestamp;

            for (let particle_i = 0; particle_i < this.n_particles; particle_i++) {
                const data_i = this.particle_i_to_data_offset(particle_i, this.particle_data_stride);
                const mesh_data_i = this.particle_i_to_data_offset(particle_i, this.mesh_data_stride);

                let px = this.particle_data[data_i + _x_offset];
                let py = this.particle_data[data_i + _y_offset];
                const vx = this.particle_data[data_i + _velocity_x_offset];
                const vy = this.particle_data[data_i + _velocity_y_offset];
                const r = this.particle_data[data_i + _r_offset] * blend_strength;
                const g = this.particle_data[data_i + _g_offset] * blend_strength;
                const b = this.particle_data[data_i + _b_offset] * blend_strength;
                const a = this.particle_data[data_i + _a_offset] * 1;
                let radius = this.particle_data[data_i + _radius_offset] * this.texture_scale

                radius *= this.mix(min_radius_scale, max_radius_scale, 0.5 * (1 + Math.cos(this.particle_data[data_i + _radius_cycle_offset] * Math.PI * (this.elapsed + particle_i))))

                px = px + vx * elapsed;
                py = py + vy * elapsed;

                const top_left_x = px - radius, top_left_y = py - radius;
                const top_right_x = px + radius, top_right_y = py - radius;
                const bottom_right_x = px + radius, bottom_right_y = py + radius;
                const bottom_left_x = px - radius, bottom_left_y = py + radius;

                let offset = 0;
                this.mesh_data[mesh_data_i + offset + 0] = top_left_x;
                this.mesh_data[mesh_data_i + offset + 1] = top_left_y;
                this.mesh_data[mesh_data_i + offset + 2] = 0;
                this.mesh_data[mesh_data_i + offset + 3] = 0;
                this.mesh_data[mesh_data_i + offset + 4] = r;
                this.mesh_data[mesh_data_i + offset + 5] = g;
                this.mesh_data[mesh_data_i + offset + 6] = b;
                this.mesh_data[mesh_data_i + offset + 7] = a;

                offset += this.mesh_vertex_stride;
                this.mesh_data[mesh_data_i + offset + 0] = top_right_x;
                this.mesh_data[mesh_data_i + offset + 1] = top_right_y;
                this.mesh_data[mesh_data_i + offset + 2] = 1;
                this.mesh_data[mesh_data_i + offset + 3] = 0;
                this.mesh_data[mesh_data_i + offset + 4] = r;
                this.mesh_data[mesh_data_i + offset + 5] = g;
                this.mesh_data[mesh_data_i + offset + 6] = b;
                this.mesh_data[mesh_data_i + offset + 7] = a;

                offset += this.mesh_vertex_stride;
                this.mesh_data[mesh_data_i + offset + 0] = bottom_right_x;
                this.mesh_data[mesh_data_i + offset + 1] = bottom_right_y;
                this.mesh_data[mesh_data_i + offset + 2] = 1;
                this.mesh_data[mesh_data_i + offset + 3] = 1;
                this.mesh_data[mesh_data_i + offset + 4] = r;
                this.mesh_data[mesh_data_i + offset + 5] = g;
                this.mesh_data[mesh_data_i + offset + 6] = b;
                this.mesh_data[mesh_data_i + offset + 7] = a;

                offset += this.mesh_vertex_stride;
                this.mesh_data[mesh_data_i + offset + 0] = bottom_left_x;
                this.mesh_data[mesh_data_i + offset + 1] = bottom_left_y;
                this.mesh_data[mesh_data_i + offset + 2] = 0;
                this.mesh_data[mesh_data_i + offset + 3] = 1;
                this.mesh_data[mesh_data_i + offset + 4] = r;
                this.mesh_data[mesh_data_i + offset + 5] = g;
                this.mesh_data[mesh_data_i + offset + 6] = b;
                this.mesh_data[mesh_data_i + offset + 7] = a;
            }
        }

        private enforce_distance(ax: number, ay: number, bx: number, by: number, inverse_mass_a: number, inverse_mass_b: number, target_distance: number, alpha: number, lambda_before: number) {
            const eps = 1e-8;
            const delta_x = bx - ax;
            const delta_y = by - ay;
            const length = this.magnitude(delta_x, delta_y);

            if (length < eps) return [0, 0, 0, 0, lambda_before];

            const normal_x = delta_x / length;
            const normal_y = delta_y / length;

            const constraint = length - target_distance;
            const weight_sum = inverse_mass_a + inverse_mass_b;
            const denominator = weight_sum + alpha;

            if (denominator < eps) return [0, 0, 0, 0, lambda_before];

            const delta_lambda = -(constraint + alpha * lambda_before) / denominator;
            const lambda_new = lambda_before + delta_lambda;

            return [
                inverse_mass_a * delta_lambda * -normal_x,
                inverse_mass_a * delta_lambda * -normal_y,
                inverse_mass_b * delta_lambda * normal_x,
                inverse_mass_b * delta_lambda * normal_y,
                lambda_new
            ];
        }

        private enforce_inside_circle(particle_x: number, particle_y: number, particle_r: number, particle_inverse_mass: number, circle_x: number, circle_y: number, circle_r: number, alpha: number, lambda_before: number) {
            const eps = 1e-8;
            const delta_x = particle_x - circle_x;
            const delta_y = particle_y - circle_y;
            const length = this.magnitude(delta_x, delta_y);

            const constraint = length - (circle_r - particle_r);
            if (constraint <= 0 || length < eps) {
                return [0, 0, lambda_before];
            }

            const normal_x = delta_x / length;
            const normal_y = delta_y / length;

            const denominator = particle_inverse_mass + alpha;
            if (denominator < eps) return [0, 0, lambda_before];

            const delta_lambda = -(constraint + alpha * lambda_before) / denominator;
            const lambda_new = lambda_before + delta_lambda;

            return [
                particle_inverse_mass * delta_lambda * normal_x,
                particle_inverse_mass * delta_lambda * normal_y,
                lambda_new
            ];
        }

        private swirl_easing(t: number) {
            let out = Math.exp(-Math.pow((Math.PI / 1.5) * t, 2));
            out *= (1 + this.mix(0, this.max_agitation, 1 - Math.min(1, this.agitation_elapsed / this.agitation_duration)));
            return out;
        }

        public step(delta: number) {
            this.elapsed += delta;

            if (this.is_paused === true) return;

            this.agitation_elapsed += delta;
            const sub_delta = delta / this.n_sub_steps;
            const collision_alpha = this.collision_compliance / (sub_delta * sub_delta);
            const orb_alpha = this.orb_compliance / (sub_delta * sub_delta);

            for (let sub_step_i = 0; sub_step_i < this.n_sub_steps; sub_step_i++) {
                // pre solve
                for (let particle_i = 0; particle_i < this.n_particles; particle_i++) {
                    const i = this.particle_i_to_data_offset(particle_i, this.particle_data_stride);

                    const x = this.particle_data[i + _x_offset];
                    const y = this.particle_data[i + _y_offset];
                    this.particle_data[i + _previous_x_offset] = x;
                    this.particle_data[i + _previous_y_offset] = y;

                    let velocity_x = this.particle_data[i + _velocity_x_offset] * this.damping;
                    let velocity_y = this.particle_data[i + _velocity_y_offset] * this.damping;

                    velocity_x += sub_delta * this.gravity_dx * this.gravity;
                    velocity_y += sub_delta * this.gravity_dy * this.gravity;

                    let dxy = this.normalize(
                        x - this.orb_center_x,
                        y - this.orb_center_y
                    );

                    let orthogonal_dxy = this.particle_data[i + _swirl_direction_offset] >= 0 ? this.turn_left(dxy[0], dxy[1]) : this.turn_right(dxy[0], dxy[1]);
                    let strength = this.swirl_easing(1 - Math.min(1, this.distance(x, y, this.orb_center_x, this.orb_center_y) / this.orb_radius));
                            velocity_x += orthogonal_dxy[0] * strength * swirl_strength * delta;
                    velocity_y += orthogonal_dxy[1] * strength * swirl_strength * delta;

                    this.particle_data[i + _velocity_x_offset] = velocity_x;
                    this.particle_data[i + _velocity_y_offset] = velocity_y;

                    this.particle_data[i + _x_offset] = x + sub_delta * velocity_x;
                    this.particle_data[i + _y_offset] = y + sub_delta * velocity_y;

                    this.particle_data[i + _orb_lambda_offset] = 0;
                }

                for (let i = 0; i < this.n_particles * this.n_particles; i++) {
                    this.particle_collision_lambdas[i] = 0;
                }

                for (let constraint_iteration_i = 0; constraint_iteration_i < this.n_constraint_iterations; constraint_iteration_i++) {
                    // particle - particle collision
                    for (let self_particle_i = 0; self_particle_i < this.n_particles; self_particle_i++) {
                        for (let other_particle_i = 0; other_particle_i < this.n_particles; other_particle_i++) {
                            if (self_particle_i !== other_particle_i) {
                                const self_i = this.particle_i_to_data_offset(self_particle_i, this.particle_data_stride);
                                const other_i = this.particle_i_to_data_offset(other_particle_i, this.particle_data_stride);

                                const lambda_i = this.particle_is_to_lambda_i(self_particle_i, other_particle_i, this.n_particles);

                                const self_x = this.particle_data[self_i + _x_offset];
                                const self_y = this.particle_data[self_i + _y_offset];
                                const self_r = this.particle_data[self_i + _radius_offset];
                                const self_inv_mass = this.particle_data[self_i + _inverse_mass_offset];

                                const other_x = this.particle_data[other_i + _x_offset];
                                const other_y = this.particle_data[other_i + _y_offset];
                                const other_r = this.particle_data[other_i + _radius_offset];
                                const other_inv_mass = this.particle_data[other_i + _inverse_mass_offset];

                                const min_distance = self_r + other_r;
                                const squared_distance = this.squared_distance(self_x, self_y, other_x, other_y);

                                if (squared_distance <= min_distance * min_distance) {
                                    const [self_cx, self_cy, other_cx, other_cy, lambda] = this.enforce_distance(
                                        self_x, self_y, other_x, other_y,
                                        self_inv_mass, other_inv_mass,
                                        min_distance, collision_alpha,
                                        this.particle_collision_lambdas[lambda_i]
                                    );

                                    this.particle_data[self_i + _x_offset] = self_x + self_cx;
                                    this.particle_data[self_i + _y_offset] = self_y + self_cy;
                                    this.particle_data[other_i + _x_offset] = other_x + other_cx;
                                    this.particle_data[other_i + _y_offset] = other_y + other_cy;
                                    this.particle_collision_lambdas[lambda_i] = lambda;
                                }
                            }
                        }
                    }

                    // particle - orb collision
                    for (let particle_i = 0; particle_i < this.n_particles; particle_i++) {
                        const self_i = this.particle_i_to_data_offset(particle_i, this.particle_data_stride);
                        const self_x = this.particle_data[self_i + _x_offset];
                        const self_y = this.particle_data[self_i + _y_offset];
                        const self_r = this.particle_data[self_i + _radius_offset];
                        const self_inv_mass = this.particle_data[self_i + _inverse_mass_offset];

                        const [cx, cy, lambda] = this.enforce_inside_circle(
                            self_x, self_y, self_r, self_inv_mass,
                            this.orb_center_x, this.orb_center_y, this.orb_radius,
                            orb_alpha, this.particle_data[self_i + _orb_lambda_offset]
                        );

                        this.particle_data[self_i + _x_offset] = self_x + cx;
                        this.particle_data[self_i + _y_offset] = self_y + cy;
                        this.particle_data[self_i + _orb_lambda_offset] = lambda;
                    }
                }

                // post solve
                for (let particle_i = 0; particle_i < this.n_particles; particle_i++) {
                    const i = this.particle_i_to_data_offset(particle_i, this.particle_data_stride);
                    const x = this.particle_data[i + _x_offset];
                    const y = this.particle_data[i + _y_offset];

                    this.particle_data[i + _velocity_x_offset] = (x - this.particle_data[i + _previous_x_offset]) / sub_delta;
                    this.particle_data[i + _velocity_y_offset] = (y - this.particle_data[i + _previous_y_offset]) / sub_delta;
                }
            }

            this.timestamp = performance.now() / 1000;
            this.update_mesh_data();
        }

        public agitate() {
            this.agitation_elapsed = 0;
        }

        // ====================================================================
        // Event Binding and Renders
        // ====================================================================

        private bindEvents() {
            window.addEventListener("resize", this.handle_resize);
            window.addEventListener("scroll", this.update_orb_position, { passive: true });
            this.update_orb_position();

            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    this.is_paused = !entry.isIntersecting;
                });
            }, {
                root: null,
                threshold: 0
            });
            observer.observe(this.canvas);

            this.canvas.addEventListener("click", () => {
                this.agitate();
            });
        }

        private update_circle_vertices(center_x: number, center_y: number, radius: number) {
            this.circle_vertices[0] = center_x;
            this.circle_vertices[1] = center_y;
            for (let segment_i = 0; segment_i < this.n_circle_segments; segment_i++) {
                const angle = (segment_i / this.n_circle_segments) * 2 * Math.PI;
                this.circle_vertices[(1 + segment_i) * 2 + 0] = center_x + Math.cos(angle) * radius;
                this.circle_vertices[(1 + segment_i) * 2 + 1] = center_y + Math.sin(angle) * radius;
            }
        }

        private renderToFramebuffer() {
            this.gl.bindFramebuffer(this.gl.FRAMEBUFFER, this.fbo);
            this.gl.viewport(0, 0, this.renderTexWidth, this.renderTexHeight);
            this.gl.enable(this.gl.STENCIL_TEST);
            this.gl.clear(this.gl.COLOR_BUFFER_BIT | this.gl.STENCIL_BUFFER_BIT);

            // Pass 1: stencil mask
            this.gl.stencilFunc(this.gl.ALWAYS, 1, 0xFF);
            this.gl.stencilOp(this.gl.KEEP, this.gl.KEEP, this.gl.REPLACE);
            this.gl.stencilMask(0xFF);
            this.gl.colorMask(false, false, false, false);
            this.gl.disable(this.gl.BLEND);

            const { position_x, position_y, radius } = this.get_position();
            this.update_circle_vertices(position_x, position_y, radius);

            this.gl.useProgram(this.stencil_program);
            this.gl.uniform2f(this.locs.stencil.canvasSize, this.renderTexWidth, this.renderTexHeight);
            this.gl.uniform2f(this.locs.stencil.offset, this.offsetUniform[0], this.offsetUniform[1]);

            this.gl.bindVertexArray(this.circleVao);
            this.gl.bindBuffer(this.gl.ARRAY_BUFFER, this.circleVertexBuffer);
            this.gl.bufferData(this.gl.ARRAY_BUFFER, this.circle_vertices, this.gl.DYNAMIC_DRAW);
            this.gl.drawElements(this.gl.TRIANGLES, this.n_circle_segments * 3, this.gl.UNSIGNED_SHORT, 0);

            // Pass 2: particles with additive blending
            this.gl.stencilFunc(this.gl.EQUAL, 1, 0xFF);
            this.gl.stencilOp(this.gl.KEEP, this.gl.KEEP, this.gl.KEEP);
            this.gl.stencilMask(0x00);
            this.gl.colorMask(true, true, true, true);
            this.gl.enable(this.gl.BLEND);
            this.gl.blendFuncSeparate(
                this.gl.SRC_ALPHA,           // srcRGB
                this.gl.ONE_MINUS_SRC_ALPHA, // dstRGB
                this.gl.ONE,                 // srcAlpha
                this.gl.ONE                  // dstAlpha
            );

            this.gl.useProgram(this.program);
            this.gl.uniform2f(this.locs.particle.canvasSize, this.renderTexWidth, this.renderTexHeight);
            this.gl.uniform2f(this.locs.particle.offset, this.offsetUniform[0], this.offsetUniform[1]);
            this.gl.uniform1i(this.locs.particle.texture, 0);

            this.gl.bindVertexArray(this.vao);
            this.gl.bindBuffer(this.gl.ARRAY_BUFFER, this.vertexBuffer);
            this.gl.bufferData(this.gl.ARRAY_BUFFER, this.mesh_data, this.gl.DYNAMIC_DRAW);

            this.gl.activeTexture(this.gl.TEXTURE0);
            this.gl.bindTexture(this.gl.TEXTURE_2D, this.particleTexture);

            this.gl.drawElements(this.gl.TRIANGLES, this.n_particles * this.mesh_vertex_map_stride, this.gl.UNSIGNED_SHORT, 0);

            this.gl.bindVertexArray(null);
            this.gl.disable(this.gl.BLEND);
            this.gl.disable(this.gl.STENCIL_TEST);
            this.gl.bindFramebuffer(this.gl.FRAMEBUFFER, null);
        }

        private renderToScreen() {
            this.gl.viewport(0, 0, this.canvasWidth, this.canvasHeight);
            this.gl.clear(this.gl.COLOR_BUFFER_BIT);
            this.gl.disable(this.gl.BLEND);
            this.gl.disable(this.gl.STENCIL_TEST);

            this.gl.useProgram(this.quad_program);
            this.gl.uniform1i(this.locs.quad.renderTexture, 1);
            this.gl.uniform1f(this.locs.quad.threshold, threshold);
            this.gl.uniform1f(this.locs.quad.eps, eps);

            this.gl.activeTexture(this.gl.TEXTURE1);
            this.gl.bindTexture(this.gl.TEXTURE_2D, this.renderTexture);

            this.gl.bindVertexArray(this.quadVao);
            this.gl.drawElements(this.gl.TRIANGLES, 6, this.gl.UNSIGNED_SHORT, 0);
            this.gl.bindVertexArray(null);
        }

        private renderFrame = (time : number) => {
            const delta = (time - this.previous_timestamp) / 1000;
            this.previous_timestamp = time;
            this.step(delta);

            this.renderToFramebuffer();
            this.renderToScreen();

            requestAnimationFrame(this.renderFrame);
        }

        private handle_resize = () => {
            const dpr = window.devicePixelRatio || 1;
            this.canvasWidth = 2.0 * radius + 2.0 * padding * dpr;
            this.canvasHeight = 2.0 * radius + 2.0 * padding * dpr;
            this.canvas.width = this.canvasWidth;
            this.canvas.height = this.canvasHeight;
            this.canvas.style.width = `${this.canvas.width}px`;
            this.canvas.style.height = `${this.canvas.height}px`;

            this.setupRenderTarget();
            this.initializeSimulation(this.canvasWidth, this.canvasHeight);
            this.update_orb_position();

            this.gl.bindBuffer(this.gl.ARRAY_BUFFER, this.vertexBuffer);
            this.gl.bufferData(this.gl.ARRAY_BUFFER, this.mesh_data, this.gl.DYNAMIC_DRAW);
        }

        private update_orb_position = () => {
            const rect = this.canvas.getBoundingClientRect();
            const x = (rect.left + rect.width / 2) * (this.canvasWidth / rect.width);
            const y = (rect.top + rect.height / 2) * (this.canvasHeight / rect.height);
            // this.orb_center_x = x;
            // this.orb_center_y = y;
        }
    }

    // Initialize module
    new OrbRenderer("orb_canvas");
</script>

<style>
    #orb_canvas {
        display: inline;
        width: 160px;
        height: 160px;
    }
</style>

<canvas id="orb_canvas"></canvas>