---
//
// Usage: <MarkdownRenderer id="post-slug-id"/>
//

import { getEntry, render } from "astro:content";

interface Props {
    id: string;
}

const { id } = Astro.props;

const post = await getEntry("posts", id);

if (!post) {
    throw new Error(`no post width id "${id}" at "src/content/posts/${id}.md"`);
}

const { Content } = await render(post);

import Frame from "../components/Frame.astro"
import "../styles/default.css";
---

<style>
    .content-wrapper {
        --padding-horizontal: 60px;
        padding-left: var(--padding-horizontal);
        padding-right: var(--padding-horizontal);
        padding-top: 0.5px !important;
        padding-bottom: var(--padding-horizontal);
    }

    .markdown-container {
        --heading-color: var(--default-color-emphasized);
        --text-color: var(--default-color-foreground);
        --max-width: var(--default-content-width);
        --font-body: var(--default-font);
        --font-mono: var(--default-font-mono);
        --code-color-keyword: var(--default-color-primary);
        --code-color-comment: var(--default-color-secondary);

        background-color: transparent;
        font-family: var(--default-font, system-ui, sans-serif), sans-serif;
        color: var(--default-color-foreground, inherit);

        max-width: var(--default-content-width, 100%);

        margin-inline: auto; /* keep centered */
        box-sizing: border-box;
        display: block;

        --astro-code-color-background: #1F1F23;
        --astro-code-color-text: #E3E3E3;
        --astro-code-token-constant: #FF7B00;
        --astro-code-token-string: #E633FF;
        --astro-code-token-comment: var(--default-color-secondary);
        --astro-code-token-keyword: var(--default-color-primary);
        --astro-code-token-parameter: #FFABAB;
        --astro-code-token-function: #FF21B3;
        --astro-code-token-string-expression: #E633FF;
        --astro-code-token-punctuation: #E3E3E3;
        --astro-code-token-link: #589DF6;
    }


    /* body / heading */
    .markdown-container :global(h1),
    .markdown-container :global(h2),
    .markdown-container :global(h3),
    .markdown-container :global(h4),
    .markdown-container :global(h5),
    .markdown-container :global(h6) {
        color: var(--default-color-emphasized, inherit);
    }

    .markdown-container :global(h1) { font-size: 3.5rem; }
    .markdown-container :global(h2) { font-size: 2.75rem; }
    .markdown-container :global(h3) { font-size: 2rem; }
    .markdown-container :global(h4) { font-size: 1.5rem; }
    .markdown-container :global(h5) { font-size: 1.25rem; }
    .markdown-container :global(h6) { font-size: 1.1rem; }

    .markdown-container :global(p),
    .markdown-container :global(li),
    .markdown-container :global(blockquote),
    .markdown-container :global(td),
    .markdown-container :global(th),
    .markdown-container :global(h1),
    .markdown-container :global(h2),
    .markdown-container :global(h3),
    .markdown-container :global(h4),
    .markdown-container :global(h5),
    .markdown-container :global(h6) {
        color: var(--default-color-foreground, inherit);
        font-family: var(--default-font, system-ui, sans-serif), sans-serif;
    }

    /* monospace */
    .markdown-container :global(code) {
        font-family: var(--default-font-mono, monospace), monospace;
        color: #E3E3E3;
        background-color: #1F1F23 !important;
    }

    /* code blocks */
    .markdown-container :global(pre) {
        font-family: inherit;
        background-color: #1F1F23 !important;
        margin: 2rem 0;
        border: 1px solid #505050;
        padding: 1rem;
        overflow-x: auto;
    }

    /* code blocks not inside pre */
    .markdown-container :global(code:not(pre code)) {
        border: 1px solid #505050;
        padding: 4px 4px;
        border-radius: 4px;
        display: inline-block;
        vertical-align: baseline;
        line-height: 1;
    }

    /* math */
    .markdown-container :global(.katex) {
        font-family: "Noto Math", "KaTeX_Main" !important;
        font-size: 1.2em !important;
        color: #E3E3E3 !important;
    }

    /* image styling */
    .markdown-container :global(img) {
        display: block;
        max-width: 100%;
        height: auto;
        margin: auto;
    }

    /* figure / caption support */
    .markdown-container :global(figure) {
        margin: 2rem 0;
        text-align: center;
    }

    .markdown-container :global(figcaption) {
        font-size: 0.9rem;
        color: var(--default-color-secondary);
        margin-top: 0.5rem;
    }
</style>

<div class="markdown-container">
    <Frame>
        <div class="content-wrapper">
            <Content />
        </div>
    </Frame>
</div>