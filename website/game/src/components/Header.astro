---
interface Props {
    vertex_shader?: string;
    fragment_shader?: string;
}

const {
    vertex_shader = `
    attribute vec2 position;
    attribute vec2 uv;
    
    varying vec2 texture_coords;
    uniform vec2 canvas_size;

    void main() {
      texture_coords = uv;
      gl_Position = vec4(position, 0.0, 1.0);
    }
  `,
    fragment_shader = `
    precision mediump float;
    
    varying vec2 texture_coords;
    uniform float elapsed;

    void main() {
      gl_FragColor = vec4(fract(texture_coords.xyx + elapsed), 1.0);
    }
  `,
} = Astro.props;
---

<div class="canvas-container">
    <canvas id="shader_background"></canvas>

    <div id="shader_error" class="error-overlay" hidden>
        <code id="shader_error_message"></code>
    </div>

    <nav class="centered-links">
        <a href="/home">Home</a>
        <a href="/about">About</a>
        <a href="/game">Game</a>
        <a href="/contact">Contact</a>
        <a href="/blog">Blog</a>
    </nav>
</div>

<style>
    .canvas-container {
        position: relative;
        width: 100vw;
        height: 100vh;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    #shader_background {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1;
        pointer-events: none;
        display: block;
        background: #0a0a0a;
    }

    .centered-links {
        display: flex;
        gap: 2.5rem;
        padding: 1.5rem 3rem;
        background: rgba(25, 25, 25, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 50px;
        backdrop-filter: blur(12px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        z-index: 10;
    }

    .centered-links a {
        color: #e0e0e0;
        text-decoration: none;
        font-family: system-ui, -apple-system, sans-serif;
        font-size: 1.1rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: color 0.3s ease, text-shadow 0.3s ease;
    }

    .centered-links a:hover {
        color: #00e5ff;
        text-shadow: 0 0 12px rgba(0, 229, 255, 0.6);
    }

    .error-overlay {
        position: absolute;
        inset: 1rem;
        background: rgba(180, 0, 0, 0.15);
        border: 1px solid rgba(255, 80, 80, 0.4);
        border-radius: 8px;
        padding: 1rem;
        font-family: monospace;
        font-size: 0.8rem;
        color: #ff6b6b;
        white-space: pre-wrap;
        overflow: auto;
        z-index: 100;
    }

    /* Responsive fallback for mobile devices */
    @media (max-width: 768px) {
        .centered-links {
            flex-direction: column;
            gap: 1.2rem;
            padding: 2rem;
            border-radius: 20px;
            text-align: center;
        }
    }
</style>

<script define:vars={{ vertex_shader, fragment_shader }}>
    const BORDER_PX = 20;

    const canvas = document.getElementById("shader_background");
    const gl = canvas.getContext("webgl");

    function dispatch_error(err) {
        canvas.dispatchEvent(new CustomEvent("webgl:error", {
            bubbles: true,
            detail: { message: err.message, stack: err.stack }
        }));
    }

    document.getElementById("shader_background").addEventListener("webgl:error", (e) => {
        const overlay = document.getElementById("shader_error");
        overlay.hidden = false;
        document.getElementById("shader_error_message").textContent = e.detail.message;
    });

    canvas.addEventListener("webglcontextlost", (e) => {
        e.preventDefault();
        dispatch_error(new Error("WebGL context lost"));
    });

    canvas.addEventListener("webglcontextrestored", () => {
        // re-init everything if you want to recover
    });

    function gl_check(label) {
        const err = gl.getError();
        if (err !== gl.NO_ERROR) {
            const messages = {
                [gl.INVALID_ENUM]:                  "INVALID_ENUM",
                [gl.INVALID_VALUE]:                 "INVALID_VALUE",
                [gl.INVALID_OPERATION]:             "INVALID_OPERATION",
                [gl.INVALID_FRAMEBUFFER_OPERATION]: "INVALID_FRAMEBUFFER_OPERATION",
                [gl.OUT_OF_MEMORY]:                 "OUT_OF_MEMORY",
                [gl.CONTEXT_LOST_WEBGL]:            "CONTEXT_LOST_WEBGL",
            };
            throw new Error(`WebGL error at [${label}]: ${messages[err] ?? `0x${err.toString(16)}`}`);
        }
    }

    function compile_shader(source, type) {
        const shader = gl.createShader(type);
        gl.shaderSource(shader, source);
        gl.compileShader(shader);
        if (!gl.getShaderParameter(shader, gl.COMPILE_STATUS)) {
            const log = gl.getShaderInfoLog(shader);
            gl.deleteShader(shader);
            throw new Error(`Shader compile error:\n${log}`);
        }
        return shader;
    }

    function link_program(...shaders) {
        const program = gl.createProgram();
        shaders.forEach(s => gl.attachShader(program, s));
        gl.linkProgram(program);
        if (!gl.getProgramParameter(program, gl.LINK_STATUS)) {
            const log = gl.getProgramInfoLog(program);
            gl.deleteProgram(program);
            throw new Error(`Program link error:\n${log}`);
        }
        return program;
    }

    try {
        const program = link_program(
            compile_shader(vertex_shader, gl.VERTEX_SHADER),
            compile_shader(fragment_shader, gl.FRAGMENT_SHADER)
        );
        gl.useProgram(program);
        gl_check("useProgram");

        // Setup Element (Index) Buffer — static, never changes
        // 5 quads (center + top + right + bottom + left), 2 triangles each, 3 vertices each
        const indices = new Uint16Array([
            // Center Quad
            0, 1, 2,   0, 2, 3,
            // Top Side Quad
            4, 5, 1,   4, 1, 0,
            // Right Side Quad
            5, 6, 2,   5, 2, 1,
            // Bottom Side Quad
            6, 7, 3,   6, 3, 2,
            // Left Side Quad
            7, 4, 0,   7, 0, 3
        ]);

        const ebo = gl.createBuffer();
        gl.bindBuffer(gl.ELEMENT_ARRAY_BUFFER, ebo);
        gl.bufferData(gl.ELEMENT_ARRAY_BUFFER, indices, gl.STATIC_DRAW);
        gl_check("ebo bufferData");

        // Setup Vertex Buffer — dynamic, rebuilt on resize
        const vbo = gl.createBuffer();
        gl.bindBuffer(gl.ARRAY_BUFFER, vbo);
        gl_check("vbo bind");

        const FSIZE = Float32Array.BYTES_PER_ELEMENT;

        // Map `position` attribute (2 floats, stride 4 floats, offset 0)
        const position_attrib = gl.getAttribLocation(program, "position");
        gl.enableVertexAttribArray(position_attrib);
        gl.vertexAttribPointer(position_attrib, 2, gl.FLOAT, false, FSIZE * 4, 0);
        gl_check("position attrib");

        // Map `uv` attribute (2 floats, stride 4 floats, offset 2 floats)
        const uv_attrib = gl.getAttribLocation(program, "uv");
        gl.enableVertexAttribArray(uv_attrib);
        gl.vertexAttribPointer(uv_attrib, 2, gl.FLOAT, false, FSIZE * 4, FSIZE * 2);
        gl_check("uv attrib");

        const elapsed_uniform = gl.getUniformLocation(program, "elapsed");
        const canvas_size_uniform = gl.getUniformLocation(program, "canvas_size");

        /**
         * Rebuilds the vertex buffer so the outer boundary sits exactly
         * BORDER_PX pixels inward from the canvas edges (in NDC).
         *
         * NDC x: pixel_x / width  * 2 - 1
         * NDC y: pixel_y / height * 2 - 1  (y-up, so top = +1)
         *
         * The outer quad is the full screen (-1..1).
         * The inner quad is inset by BORDER_PX on every side.
         */
        function build_vertices(width, height) {
            const bx = (BORDER_PX / width)  * 2;   // border in NDC x
            const by = (BORDER_PX / height) * 2;   // border in NDC y

            // Inner quad corners (inset from screen edges by BORDER_PX)
            const il = -1.0 + bx;   // inner left   NDC x
            const ir =  1.0 - bx;   // inner right  NDC x
            const it =  1.0 - by;   // inner top    NDC y
            const ib = -1.0 + by;   // inner bottom NDC y

            return new Float32Array([
                // Inner quad (u=0), v encodes arc-length around the loop
                il,  it,  0.0, 0.0,    // 0: Inner Top-Left
                ir,  it,  0.0, 0.25,   // 1: Inner Top-Right
                ir,  ib,  0.0, 0.5,    // 2: Inner Bottom-Right
                il,  ib,  0.0, 0.75,   // 3: Inner Bottom-Left

                // Outer quad boundary (u=1), full screen edges
                -1.0,  1.0,  1.0, 0.0,    // 4: Outer Top-Left
                1.0,  1.0,  1.0, 0.25,   // 5: Outer Top-Right
                1.0, -1.0,  1.0, 0.5,    // 6: Outer Bottom-Right
                -1.0, -1.0,  1.0, 0.75,   // 7: Outer Bottom-Left
            ]);
        }

        function resize() {
            const dpr = window.devicePixelRatio ?? 1;
            canvas.width  = Math.floor(window.innerWidth  * dpr);
            canvas.height = Math.floor(window.innerHeight * dpr);
            gl.viewport(0, 0, canvas.width, canvas.height);
            gl.uniform2f(canvas_size_uniform, canvas.width, canvas.height);

            // Re-upload vertex data with updated NDC inset for the new dimensions
            const vertices = build_vertices(canvas.width, canvas.height);
            gl.bindBuffer(gl.ARRAY_BUFFER, vbo);
            gl.bufferData(gl.ARRAY_BUFFER, vertices, gl.DYNAMIC_DRAW);
            gl_check("resize bufferData");
        }

        resize();
        new ResizeObserver(resize).observe(document.documentElement);

        function render(elapsedstamp) {
            gl.uniform1f(elapsed_uniform, elapsedstamp / 1000.0);
            gl.drawElements(gl.TRIANGLES, indices.length, gl.UNSIGNED_SHORT, 0);
            requestAnimationFrame(render);
        }

        requestAnimationFrame(render);
    } catch (err) {
        dispatch_error(err);
    }
</script>